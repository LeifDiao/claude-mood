# Claude Mood is a tiny local dashboard (a Node server + two HTML pages), not a code
# library — hide the GitHub "Languages" bar by excluding everything from Linguist's
# language statistics.
*.html    linguist-documentation
*.js      linguist-detectable=false
*.css     linguist-detectable=false
*.json    linguist-detectable=false
*.md      linguist-documentation
*.command linguist-detectable=false
docs/index.html linguist-generated
